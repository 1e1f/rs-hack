{
  "name": "yah-ui",
  "version": "0.1.0",
  "description": "yah desktop UI — Tauri + web frontend for the unified harness",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n js,css,srv -c cyan,magenta,green \"bun run dev:js\" \"bun run dev:css\" \"bun run dev:serve\"",
    "dev:js": "bun build --watch src/main.tsx --outdir public/dist --target=browser --sourcemap=external",
    "dev:css": "bunx @tailwindcss/cli -i src/styles/globals.css -o public/dist/app.css --watch",
    "dev:serve": "bun run serve.ts",
    "build": "bun run build:css && bun run build:js",
    "build:js": "bun build src/main.tsx --outdir public/dist --target=browser --minify",
    "build:css": "bunx @tailwindcss/cli -i src/styles/globals.css -o public/dist/app.css --minify",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-store": "^2.0.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "mermaid": "^11.4.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@tailwindcss/cli": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.3"
  }
}
