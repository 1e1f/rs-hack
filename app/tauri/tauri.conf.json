{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yah",
  "version": "0.6.0",
  "identifier": "com.yah.app",
  "build": {
    "frontendDist": "../../yah-ui/public",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../yah-ui && bun run dev",
    "beforeBuildCommand": "cd ../../yah-ui && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "yah",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
