{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yah",
  "version": "0.6.0",
  "identifier": "com.yah.app",
  "build": {
    "frontendDist": "../../../packages/yah/ui/public",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../packages/yah/ui && bun run dev",
    "beforeBuildCommand": "cd ../../packages/yah/ui && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "yah",
        "width": 1500,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
